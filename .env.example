# ─────────────────────────────────────────────
#  LeetCode Discord Bot  ─  Environment Variables
# ─────────────────────────────────────────────

# REQUIRED ─ Your Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# REQUIRED ─ The ID of the Discord text channel where reports will be posted
#            Right-click the channel → "Copy Channel ID" (Developer Mode must be on)
DISCORD_CHANNEL_ID=
DISCORD_ARCHIVE_CHANNEL_ID=

# OPTIONAL ─ MongoDB Atlas Connection URI for cloud hosting
#            If left blank, the bot will use local JSON files.
MONGODB_URI=

# OPTIONAL ─ Your local timezone (default: Asia/Kolkata)
#            Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=Asia/Kolkata

# OPTIONAL ─ Hour (0-23) at which the daily job runs in local time (default: 0 = midnight)
DAILY_RUN_HOUR=0

# OPTIONAL ─ Minute (0-59) at which the daily job runs (default: 0)
DAILY_RUN_MINUTE=0

# OPTIONAL ─ Log level: DEBUG | INFO | WARNING | ERROR (default: INFO)
LOG_LEVEL=INFO
